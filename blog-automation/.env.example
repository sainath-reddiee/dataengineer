# Required
GEMINI_API_KEY=AIzaSyCeFh7vASFx3iHV-
WORDPRESS_URL=https://yourdomain.com
WORDPRESS_USER=psainath123@gmail.com
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional (for images)
USE_IMAGES=false
# HUGGINGFACE_API_KEY=hf_xxxx  
# Uncomment if USE_IMAGES=true

# Optional (for research)
TAVILY_API_KEY=tvly-xxxxxxxxxxxx

# Optional (custom output)
OUTPUT_DIR=blog_outputs

# V2 Generator Config
# Model to use for content generation (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
# Path to author persona config (default: author_config.json)
AUTHOR_CONFIG=author_config.json

# ---- Multi-Provider LLM Fallback (Optional) ----
# Fallback chain: gemini -> gemini_backup -> groq -> cerebras -> together -> mistral -> openrouter -> cloudflare -> openai
# If primary Gemini quota is exhausted, the pipeline tries these in order.
# Once a provider hits quota, it's skipped for the rest of the pipeline run.

# Backup Gemini key (separate quota pool)
GEMINI_API_KEY_2=

# Groq (free tier: llama-3.3-70b-versatile)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras (free tier: llama-3.3-70b)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Together AI (free tier: meta-llama/Llama-3.3-70B-Instruct-Turbo)
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Mistral (free tier: mistral-small-latest)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# OpenRouter (free tier: meta-llama/llama-3.3-70b-instruct:free)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Cloudflare Workers AI (free tier: @cf/meta/llama-3.3-70b-instruct-fp8)
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8

# OpenAI (paid: gpt-4o-mini)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Rate limiting
GEMINI_REQUEST_DELAY=3
GEMINI_SECTION_DELAY=4
