# .env.example
# Copy this to .env and fill in your values

# Admin Auth (SHA-256 hashes of your username and password)
# Generate with: node -e "require('crypto').createHash('sha256').update('your-value').digest('hex')"
VITE_ADMIN_USER_HASH=your-sha256-username-hash
VITE_ADMIN_PASS_HASH=your-sha256-password-hash

# AdSense Configuration
VITE_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXX
VITE_ADS_ENABLED=false

# AdSense for pSEO pages (used by static page generator)
# Set this to enable ads on glossary/comparison pages
ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXX

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Giscus Comments (GitHub Discussions)
VITE_GISCUS_REPO=your-username/your-repo
VITE_GISCUS_REPO_ID=your-repo-id
VITE_GISCUS_CATEGORY=General
VITE_GISCUS_CATEGORY_ID=your-category-id

# Buttondown Newsletter
VITE_BUTTONDOWN_API_KEY=your-buttondown-api-key
