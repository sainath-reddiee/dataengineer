                    "value": "noindex, nofollow"
                }
            ]
        },
        {
            "source": "/news",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, nofollow"
                }
            ]
        },
        {
            "source": "/tag/:path*",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, follow"
                }
            ]
        },
        {
            "source": "/category/:path*",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex, follow"
                }
            ]
        },
        {
            "source": "/newsletter",
