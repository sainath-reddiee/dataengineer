{
    "redirects": [
        {
            "source": "/:path(.*)/",
            "destination": "/:path*",
            "permanent": true
        },
        {
            "source": "http://dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        },
        {
            "source": "http://www.dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        },
        {
            "source": "https://www.dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
                { "key": "X-XSS-Protection", "value": "1; mode=block" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(.*).html",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
            ]
        },
        {
            "source": "/glossary/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/compare/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/tools/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/cheatsheets/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/practice/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/interview-prep/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/admin/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
            ]
        },
        {
            "source": "/admin",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
            ]
        },
        {
            "source": "/debug",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
            ]
        },
        {
            "source": "/news",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
            ]
        }
    ],
    {
  "redirects": [
    { "source": "/glossary",            "destination": "/articles", "permanent": false },
    { "source": "/glossary/:term",      "destination": "/articles", "permanent": false },
    { "source": "/compare",             "destination": "/articles", "permanent": false },
    { "source": "/compare/:slug",       "destination": "/articles", "permanent": false },
    { "source": "/cheatsheets",         "destination": "/articles", "permanent": false },
    { "source": "/cheatsheets/:path*",  "destination": "/articles", "permanent": false },
    { "source": "/tools",               "destination": "/articles", "permanent": false },
    { "source": "/tools/:slug",         "destination": "/articles", "permanent": false },
    { "source": "/interview-prep",      "destination": "/articles", "permanent": false },
    { "source": "/practice/:path*",     "destination": "/articles", "permanent": false }
  ]
   }
}
