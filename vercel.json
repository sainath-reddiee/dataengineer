{
    "redirects": [
        {
            "source": "/:path(.*)/",
            "destination": "/:path*",
            "permanent": true
        },
        {
            "source": "http://dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        },
        {
            "source": "http://www.dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        },
        {
            "source": "https://www.dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
                { "key": "X-XSS-Protection", "value": "1; mode=block" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(.*).html",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
            ]
        },
        {
            "source": "/glossary/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/compare/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/tools/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/cheatsheets/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/practice/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        },
        {
            "source": "/interview-prep/:path*",
            "headers": [
                { "key": "X-Robots-Tag", "value": "noindex, follow" }
            ]
        }
    ],
    "rewrites": [
        { "source": "/", "destination": "/index.html" },
        { "source": "/articles", "destination": "/articles/index.html" },
        { "source": "/articles/:slug", "destination": "/articles/:slug/index.html" },
        { "source": "/category/:slug", "destination": "/category/:slug/index.html" },
        { "source": "/tag", "destination": "/index.html" },
        { "source": "/tag/:slug", "destination": "/tag/:slug/index.html" },

        { "source": "/about", "destination": "/about/index.html" },
        { "source": "/contact", "destination": "/contact/index.html" },
        { "source": "/privacy-policy", "destination": "/privacy-policy/index.html" },
        { "source": "/terms-of-service", "destination": "/terms-of-service/index.html" },
        { "source": "/disclaimer", "destination": "/disclaimer/index.html" },
        { "source": "/newsletter", "destination": "/index.html" },
        { "source": "/contribute", "destination": "/index.html" },
        { "source": "/news", "destination": "/index.html" },
        { "source": "/certification", "destination": "/index.html" },

        { "source": "/glossary", "destination": "/index.html" },
        { "source": "/glossary/:term", "destination": "/index.html" },
        { "source": "/compare", "destination": "/index.html" },
        { "source": "/compare/:slug", "destination": "/index.html" },
        { "source": "/cheatsheets", "destination": "/index.html" },
        { "source": "/cheatsheets/:slug", "destination": "/index.html" },
        { "source": "/cheatsheets/category/:cat", "destination": "/index.html" },

        { "source": "/tools", "destination": "/index.html" },
        { "source": "/tools/:slug", "destination": "/index.html" },

        { "source": "/practice", "destination": "/index.html" },
        { "source": "/practice/:slug", "destination": "/index.html" },
        { "source": "/practice/:slug/topics/:topicSlug", "destination": "/index.html" },
        { "source": "/practice/:slug/q/:questionSlug", "destination": "/index.html" },
        { "source": "/interview-prep", "destination": "/index.html" },

        { "source": "/admin", "destination": "/index.html" },
        { "source": "/admin/:path*", "destination": "/index.html" }
    ]
}
