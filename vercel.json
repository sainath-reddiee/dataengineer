# Vercel Configuration for Canonical URLs and Performance
{
    "redirects": [
        {
            "source": "/:path(.*)/",
            "destination": "/:path*",
            "permanent": true
        },
        {
            "source": "http://dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        },
        {
            "source": "http://www.dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        },
        {
            "source": "https://www.dataengineerhub.blog/:path*",
            "destination": "https://dataengineerhub.blog/:path*",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*).html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/articles/:slug",
            "destination": "/articles/:slug/index.html"
        },
        {
            "source": "/category/:slug",
            "destination": "/category/:slug/index.html"
        },
        {
            "source": "/tag/:slug",
            "destination": "/tag/:slug/index.html"
        },
        {
            "source": "/about",
            "destination": "/about/index.html"
        },
        {
            "source": "/contact",
            "destination": "/contact/index.html"
        },
        {
            "source": "/privacy-policy",
            "destination": "/privacy-policy/index.html"
        },
        {
            "source": "/terms-of-service",
            "destination": "/terms-of-service/index.html"
        },
        {
            "source": "/disclaimer",
            "destination": "/disclaimer/index.html"
        },
        {
            "source": "/articles",
            "destination": "/articles/index.html"
        },
        {
            "source": "/glossary",
            "destination": "/glossary/index.html"
        },
        {
            "source": "/glossary/:term",
            "destination": "/glossary/:term/index.html"
        },
        {
            "source": "/compare",
            "destination": "/compare/index.html"
        },
        {
            "source": "/compare/:slug",
            "destination": "/compare/:slug/index.html"
        },
        {
            "source": "/cheatsheets",
            "destination": "/cheatsheets/index.html"
        },
        {
            "source": "/cheatsheets/:slug",
            "destination": "/cheatsheets/:slug/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}